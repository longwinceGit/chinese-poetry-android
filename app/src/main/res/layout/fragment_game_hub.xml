<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="20dp">

    <TextView
        android:id="@+id/tv_game_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/game_title"
        android:textSize="22sp"
        android:textColor="@color/primary"
        android:fontFamily="serif"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_game_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/game_subtitle"
        android:textSize="13sp"
        android:textColor="@color/on_surface_variant"
        app:layout_constraintTop_toBottomOf="@id/tv_game_title"
        app:layout_constraintStart_toStartOf="@id/tv_game_title" />

    <!-- 对诗 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_couplet"
        style="@style/Widget.Poetry.Card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardElevation="2dp"
        app:cardCornerRadius="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_game_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="📝"
                android:textSize="28sp"
                android:gravity="center"
                android:background="@drawable/bg_checkin_future" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/game_couplet"
                    android:textSize="16sp"
                    android:textColor="@color/on_surface"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/game_couplet_desc"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_variant" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="→"
                android:textSize="20sp"
                android:textColor="@color/outline" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 消消乐 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_match"
        style="@style/Widget.Poetry.Card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardElevation="2dp"
        app:cardCornerRadius="16dp"
        app:layout_constraintTop_toBottomOf="@id/card_couplet"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="🃏"
                android:textSize="28sp"
                android:gravity="center"
                android:background="@drawable/bg_checkin_future" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/game_match"
                    android:textSize="16sp"
                    android:textColor="@color/on_surface"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/game_match_desc"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_variant" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="→"
                android:textSize="20sp"
                android:textColor="@color/outline" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 填空 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_quiz"
        style="@style/Widget.Poetry.Card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardElevation="2dp"
        app:cardCornerRadius="16dp"
        app:layout_constraintTop_toBottomOf="@id/card_match"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="✏️"
                android:textSize="28sp"
                android:gravity="center"
                android:background="@drawable/bg_checkin_future" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/game_quiz"
                    android:textSize="16sp"
                    android:textColor="@color/on_surface"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/game_quiz_desc"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_variant" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="→"
                android:textSize="20sp"
                android:textColor="@color/outline" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>

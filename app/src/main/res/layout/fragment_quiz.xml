<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- 顶部栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="@color/card"
        android:elevation="2dp">

        <TextView
            android:id="@+id/btn_quiz_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="←"
            android:textSize="22sp"
            android:textColor="@color/text_primary"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✏️ 我会背"
            android:textSize="18sp"
            android:textColor="@color/coral"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/tv_quiz_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="第1题"
            android:textSize="14sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- 诗词标题 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tv_quiz_poem_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="静夜思"
            android:textSize="20sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_quiz_poem_author"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="李白 · 唐代"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- 诗句展示区 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="16dp"
        android:layout_marginTop="0dp"
        android:background="@drawable/bg_card"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:id="@+id/layout_quiz_lines"
            android:gravity="center" />
    </ScrollView>

    <!-- 候选词区域 -->
    <LinearLayout
        android:id="@+id/layout_candidates"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="16dp"
        android:orientation="vertical" />

    <!-- 底部按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="12dp"
        android:background="@color/card"
        android:elevation="4dp">

        <TextView
            android:id="@+id/btn_quiz_tip"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="💡 提示"
            android:textSize="15sp"
            android:textColor="@color/text_secondary"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_quiz_submit"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="✅ 确认"
            android:textSize="15sp"
            android:textColor="@color/card"
            android:background="@drawable/bg_button_primary"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="12dp" />

        <TextView
            android:id="@+id/btn_quiz_next"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="➡️ 下一题"
            android:textSize="15sp"
            android:textColor="@color/teal"
            android:visibility="gone"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="12dp" />
    </LinearLayout>

</LinearLayout>

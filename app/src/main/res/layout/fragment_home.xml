<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- 顶部栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:background="@color/card"
        android:elevation="2dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="诗词乐园"
                android:textSize="22sp"
                android:textColor="@color/coral"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="每天学一首古诗"
                android:textSize="12sp"
                android:textColor="@color/text_light" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_learning"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="学习看板">

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                app:srcCompat="@drawable/ic_learning"
                android:scaleType="fitCenter" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_game"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="游戏">

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                app:srcCompat="@drawable/ic_game"
                android:scaleType="fitCenter" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_search_toggle"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="搜索">

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                app:srcCompat="@drawable/ic_search"
                android:scaleType="fitCenter" />
        </LinearLayout>
    </LinearLayout>

    <!-- 搜索栏 -->
    <LinearLayout
        android:id="@+id/search_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="@color/card"
        android:visibility="gone"
        android:elevation="2dp">

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/et_search"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_chip"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:hint="搜索诗词、作者、诗句..."
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_light"
            android:singleLine="true"
            android:imeOptions="actionSearch" />

        <TextView
            android:id="@+id/btn_search_close"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="✕"
            android:textSize="18sp"
            android:textColor="@color/text_secondary"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

    <!-- 可滚动主内容 -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- 每日推荐 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/daily_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                card_view:cardCornerRadius="20dp"
                card_view:cardElevation="2dp"
                card_view:cardBackgroundColor="@color/coral_soft">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🌟 今日推荐"
                            android:textSize="13sp"
                            android:textColor="@color/coral"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_daily_pinyin_toggle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="8dp"
                            android:text="🔤"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="4dp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_daily_emoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📖"
                        android:textSize="40sp"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:id="@+id/ll_daily_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center" />

                    <LinearLayout
                        android:id="@+id/ll_daily_author"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 分类标签 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="分类浏览"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/category_chips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical" />
            </HorizontalScrollView>

            <!-- 搜索结果标题 -->
            <TextView
                android:id="@+id/tv_search_result_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="搜索结果"
                android:textSize="15sp"
                android:textColor="@color/coral"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <!-- 全部诗词标题 -->
            <LinearLayout
                android:id="@+id/section_all_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📚 全部诗词"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_poem_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0首"
                    android:textSize="12sp"
                    android:textColor="@color/text_light" />
            </LinearLayout>

            <!-- 诗词网格 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_poems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <!-- 加载更多 -->
            <LinearLayout
                android:id="@+id/load_more_area"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/btn_load_more"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:gravity="center"
                    android:text="📖 加载更多"
                    android:textSize="15sp"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_chip"
                    android:clickable="true"
                    android:focusable="true" />

                <ProgressBar
                    android:id="@+id/progress_load"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:visibility="gone"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>

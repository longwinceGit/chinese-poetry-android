<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <!-- ========== 搜索栏 ========== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/search_card"
            style="@style/Widget.Poetry.Card"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="24dp"
            app:strokeWidth="0dp"
            app:contentPadding="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="16dp"
                android:paddingEnd="8dp">

                <ImageView
                    android:id="@+id/iv_search_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_search"
                    android:contentDescription="搜索"
                    android:alpha="0.5"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="8dp"
                    android:background="@null"
                    android:hint="@string/home_search_hint"
                    android:textColor="@color/on_surface"
                    android:textColorHint="@color/outline_variant"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    app:layout_constraintStart_toEndOf="@id/iv_search_icon"
                    app:layout_constraintEnd_toStartOf="@id/btn_search_clear"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <ImageButton
                    android:id="@+id/btn_search_clear"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_close"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="清除搜索"
                    android:visibility="gone"
                    android:alpha="0.5"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ========== 每日推荐卡片 ========== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/daily_card"
            style="@style/Widget.Poetry.Card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="16dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="16dp"
            app:layout_constraintTop_toBottomOf="@id/search_card"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_daily_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_daily_recommend"
                    android:textColor="@color/tertiary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <LinearLayout
                    android:id="@+id/ll_daily_poem"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_daily_label">

                    <TextView
                        android:id="@+id/tv_daily_emoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="32sp"
                        tools:text="🌸" />

                    <TextView
                        android:id="@+id/tv_daily_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="20sp"
                        android:textColor="@color/primary"
                        android:fontFamily="serif"
                        android:textStyle="bold"
                        tools:text="静夜思" />

                    <TextView
                        android:id="@+id/tv_daily_author"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface_variant"
                        tools:text="李白 · 唐代" />

                    <TextView
                        android:id="@+id/tv_daily_excerpt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="13sp"
                        android:textColor="@color/on_surface_variant"
                        android:maxLines="2"
                        android:ellipsize="end"
                        tools:text="床前明月光，疑是地上霜..." />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_daily_tap_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="点击查看详情 →"
                    android:textSize="11sp"
                    android:textColor="@color/outline"
                    app:layout_constraintTop_toBottomOf="@id/ll_daily_poem"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ========== 分类标签（横向滚动） ========== -->
        <HorizontalScrollView
            android:id="@+id/hsv_categories"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:scrollbars="none"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            app:layout_constraintTop_toBottomOf="@id/daily_card"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_categories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:chipSpacingHorizontal="8dp" />
        </HorizontalScrollView>

        <!-- ========== 搜索结果标题 ========== -->
        <TextView
            android:id="@+id/tv_section_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="16dp"
            android:text="@string/home_all_poems"
            android:textSize="16sp"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:fontFamily="serif"
            app:layout_constraintTop_toBottomOf="@id/hsv_categories"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ========== 搜索结果计数 ========== -->
        <TextView
            android:id="@+id/tv_poem_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/on_surface_variant"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_section_title"
            app:layout_constraintBottom_toBottomOf="@id/tv_section_title"
            android:layout_marginEnd="16dp"
            tools:text="共收录 1091 首" />

        <!-- ========== 加载状态 ========== -->
        <LinearLayout
            android:id="@+id/loading_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/tv_section_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ProgressBar
                android:id="@+id/progress_loading"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:indeterminateTint="@color/primary" />

            <TextView
                android:id="@+id/tv_loading_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/home_loading"
                android:textSize="13sp"
                android:textColor="@color/on_surface_variant" />
        </LinearLayout>

        <!-- ========== 空状态 ========== -->
        <TextView
            android:id="@+id/tv_empty"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="48dp"
            android:layout_marginEnd="32dp"
            android:text="@string/home_search_empty"
            android:textSize="14sp"
            android:textColor="@color/on_surface_variant"
            android:gravity="center"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tv_section_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ========== 诗词网格 ========== -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_poems"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="12dp"
            android:nestedScrollingEnabled="false"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tv_section_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ========== 加载更多 ========== -->
        <LinearLayout
            android:id="@+id/load_more_area"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/recycler_poems"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ProgressBar
                android:id="@+id/progress_load_more"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:indeterminateTint="@color/primary"
                android:visibility="gone"
                android:layout_marginTop="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_load_more"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="@string/home_load_more"
                android:textSize="13sp"
                style="@style/Widget.Poetry.Button.Outlined"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tv_no_more"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_no_more"
                android:textSize="12sp"
                android:textColor="@color/outline"
                android:visibility="gone"
                android:layout_marginTop="16dp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>

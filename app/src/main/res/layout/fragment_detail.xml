<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- 顶部栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="@color/card"
        android:elevation="2dp">

        <TextView
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="←"
            android:textSize="22sp"
            android:textColor="@color/text_primary"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="诗词详情"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/btn_favorite_header"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="🤍"
            android:textSize="18sp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- 标题 -->
            <TextView
                android:id="@+id/tv_detail_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="静夜思"
                android:textSize="26sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:gravity="center" />

            <!-- 拼音 -->
            <TextView
                android:id="@+id/tv_detail_pinyin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text=""
                android:textSize="13sp"
                android:textColor="@color/text_light"
                android:gravity="center"
                android:visibility="gone" />

            <!-- 作者 -->
            <TextView
                android:id="@+id/tv_detail_author"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="李白 · 唐代"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:gravity="center" />

            <!-- 分隔线 -->
            <View
                android:layout_width="60dp"
                android:layout_height="2dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:layout_gravity="center"
                android:background="@color/coral" />

            <!-- 诗句 -->
            <TextView
                android:id="@+id/tv_detail_lines"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="床前明月光，\n疑是地上霜。"
                android:textSize="18sp"
                android:textColor="@color/text_primary"
                android:lineSpacingExtra="10dp"
                android:gravity="center" />

        </LinearLayout>
    </ScrollView>

    <!-- 底部操作栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="8dp"
        android:background="@color/card"
        android:elevation="4dp">

        <LinearLayout
            android:id="@+id/btn_voice"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔊"
                android:textSize="16sp"
                android:textColor="@color/teal" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_pinyin"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:id="@+id/tv_pinyin_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔤 拼音"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_favorite"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:id="@+id/tv_fav_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🤍"
                android:textSize="16sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_quiz"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✏️"
                android:textSize="16sp"
                android:textColor="@color/coral" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>

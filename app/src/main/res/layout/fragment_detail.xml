<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="40dp">

        <!-- 装饰条 -->
        <View
            android:id="@+id/divider_top"
            android:layout_width="48dp"
            android:layout_height="2dp"
            android:layout_marginTop="24dp"
            android:background="@color/tertiary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 标题 -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toBottomOf="@id/divider_top"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:textSize="28sp"
            android:textColor="@color/primary"
            android:fontFamily="serif"
            android:textStyle="bold"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            tools:text="静夜思" />

        <!-- 作者 & 朝代 -->
        <LinearLayout
            android:id="@+id/ll_author"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tv_emoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                tools:text="🌸" />

            <TextView
                android:id="@+id/tv_author"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textSize="16sp"
                android:textColor="@color/on_surface"
                android:textStyle="bold"
                tools:text="李白" />

            <TextView
                android:id="@+id/tv_dynasty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textSize="13sp"
                android:textColor="@color/on_surface_variant"
                tools:text="唐代" />
        </LinearLayout>

        <!-- 分类标签 -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_tag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textSize="11sp"
            android:clickable="false"
            app:layout_constraintTop_toBottomOf="@id/ll_author"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="唐代" />

        <!-- 分隔线 -->
        <View
            android:id="@+id/divider_poem"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginStart="32dp"
            android:layout_marginTop="28dp"
            android:layout_marginEnd="32dp"
            android:background="@color/divider"
            app:layout_constraintTop_toBottomOf="@id/chip_tag"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 诗句内容 -->
        <LinearLayout
            android:id="@+id/ll_poem_lines"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/divider_poem"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 拼音切换按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pinyin"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginTop="16dp"
            android:text="拼音"
            android:textSize="12sp"
            style="@style/Widget.Poetry.Button.Outlined"
            app:layout_constraintTop_toBottomOf="@id/ll_poem_lines"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 释义分隔线 -->
        <View
            android:id="@+id/divider_explanation"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginStart="32dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="32dp"
            android:background="@color/divider"
            app:layout_constraintTop_toBottomOf="@id/btn_pinyin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 释义标题 -->
        <TextView
            android:id="@+id/tv_explanation_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            android:text="释义"
            android:textSize="16sp"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:fontFamily="serif"
            app:layout_constraintTop_toBottomOf="@id/divider_explanation"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- 释义内容 -->
        <TextView
            android:id="@+id/tv_explanation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="24dp"
            android:textSize="15sp"
            android:textColor="@color/on_surface"
            android:lineSpacingExtra="6dp"
            android:textAlignment="viewStart"
            app:layout_constraintTop_toBottomOf="@id/tv_explanation_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="此诗描写了……" />

        <!-- 底部操作栏 -->
        <LinearLayout
            android:id="@+id/ll_actions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="32dp"
            android:layout_marginEnd="16dp"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/tv_explanation"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_favorite"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/detail_favorite"
                android:textSize="13sp"
                app:icon="@drawable/ic_favorite"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                style="@style/Widget.Poetry.Button.Outlined" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_read"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:text="@string/detail_read"
                android:textSize="13sp"
                app:icon="@drawable/ic_volume"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                style="@style/Widget.Poetry.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_share"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/detail_share"
                android:textSize="13sp"
                app:icon="@drawable/ic_share"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                style="@style/Widget.Poetry.Button.Outlined" />

        </LinearLayout>

        <!-- 学习按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_learn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:text="@string/detail_learn"
            android:textSize="14sp"
            app:icon="@drawable/ic_check_circle"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:cornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/ll_actions"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>

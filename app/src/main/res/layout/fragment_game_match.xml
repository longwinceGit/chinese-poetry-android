<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="16dp">

    <!-- 顶部标题栏 -->
    <LinearLayout
        android:id="@+id/ll_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_game_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🃏 诗词消消乐"
            android:textSize="20sp"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:fontFamily="serif" />

        <TextView
            android:id="@+id/tv_match_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/on_surface_variant"
            tools:text="0 / 6" />
    </LinearLayout>

    <!-- 玩法说明 -->
    <TextView
        android:id="@+id/tv_instruction"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="找到每首诗的上句和下句，点击两张卡片配对消除 👇"
        android:textSize="12sp"
        android:textColor="@color/on_surface_variant"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/ll_header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 配对成功提示（诗词名） -->
    <TextView
        android:id="@+id/tv_match_tip"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textSize="13sp"
        android:textColor="@color/answer_correct"
        android:textStyle="bold"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_instruction"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="✨ 静夜思 · 李白"
        tools:visibility="visible" />

    <!-- 卡片网格 3列 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_cards"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:padding="2dp"
        app:layout_constraintTop_toBottomOf="@id/tv_match_tip"
        app:layout_constraintBottom_toTopOf="@id/btn_match_restart"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 重新开始按钮 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_match_restart"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginBottom="16dp"
        android:text="🔄 再来一局"
        android:textSize="14sp"
        app:cornerRadius="12dp"
        style="@style/Widget.Poetry.Button.Outlined"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 完成弹层 -->
    <LinearLayout
        android:id="@+id/layout_match_complete"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_card_surface"
        android:padding="20dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎉"
            android:textSize="48sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="恭喜全部消除！"
            android:textSize="20sp"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:fontFamily="serif" />

        <TextView
            android:id="@+id/tv_match_complete_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="14sp"
            android:textColor="@color/on_surface_variant"
            tools:text="得分 45  ·  尝试 8 次" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
